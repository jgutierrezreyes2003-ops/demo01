package com.example.demo.entity;

public class PersonaEntity {
    
    private Long id;
    private String nombre;

    // 1. Constructor vacío (OBLIGATORIO para que Spring pueda instanciar el objeto al recibir el formulario)
    public PersonaEntity() {
    }

    // Constructor con parámetros (opcional, pero útil)
    public PersonaEntity(Long id, String nombre) {
        this.id = id;
        this.nombre = nombre;
    }

    // 2. Getters y Setters (OBLIGATORIOS para que Spring inyecte los datos del HTML)
    public Long getId() {
        return id;
    }

    public void setId(Long id) {
        this.id = id;
    }

    public String getNombre() {
        return nombre;
    }

    public void setNombre(String nombre) {
        this.nombre = nombre;
    }
}